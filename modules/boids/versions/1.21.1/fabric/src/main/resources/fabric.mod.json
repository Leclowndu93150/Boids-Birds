{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "${mod_author}"
  ],
  "license": "${license}",
  "icon": "assets/boids/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.leclowndu93150.boids.fabric.BoidsFabric"
    ],
    "modmenu": [
      "com.leclowndu93150.boids.fabric.BoidsModMenuIntegration"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~1.21.1",
    "java": ">=${java_version}",
    "fabric-api": "*",
    "yet_another_config_lib_v3": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
